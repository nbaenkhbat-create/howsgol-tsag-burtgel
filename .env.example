PORT=3000
VERIFY_TOKEN=your_verify_token_here
PAGE_ACCESS_TOKEN=your_page_access_token_here
GROQ_API_KEY=your_groq_api_key_here
PUBLIC_BASE_URL=https://howsgol-tsag-burtgel.onrender.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
# Аль нэгийг нь ашиглана:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# эсвэл GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Admin (optional)
# SUPERADMIN_USER=admin123
# SUPERADMIN_PASS=123123
# JWT_SECRET=change-me

# Optional default company seed (Firebase тохируулаагүй үед deploy бүрийн дараа хоосрохоос хамгаална)
DEFAULT_COMPANY_NAME=bayr
DEFAULT_COMPANY_PHONE=12345678
DEFAULT_COMPANY_USERNAME=bayr
DEFAULT_COMPANY_PASSWORD=12345678
DEFAULT_COMPANY_PAGE_LINK=https://www.facebook.com/search/top?q=nowijufaqae
DEFAULT_COMPANY_INFO_PHONE=12345677
DEFAULT_COMPANY_LOCATION_LINK=https://maps.app.goo.gl/tppoPZmyL4IMq29EFG
